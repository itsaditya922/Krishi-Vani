# KrishiVani Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===== REQUIRED =====

# Telegram Bot Token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here


# ===== OPTIONAL - For WhatsApp/Twilio Integration =====

# Twilio Account credentials (from twilio.com console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ngrok public URL (for Twilio webhooks)
# Generated when running: ngrok http 5000
NGROK_URL=https://your-ngrok-url.io


# ===== OPTIONAL - Advanced Settings =====

# Flask debug mode (set to False in production)
FLASK_ENV=development
DEBUG=True

# Server port
SERVER_PORT=5000
